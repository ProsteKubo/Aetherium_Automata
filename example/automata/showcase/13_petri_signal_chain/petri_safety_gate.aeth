        "alarm_to_inhibit": {
          "id": "alarm_to_inhibit",
          "name": "alarm_to_inhibit",
          "from": "Alarm",
          "to": "Inhibit",
          "type": "classic",
          "condition": "value(\"arm_request\") == false and value(\"route_state\") == \"standby\"",
          "body": "",
          "triggered": "",
          "priority": 0,
