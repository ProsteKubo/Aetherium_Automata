          "id": "Alarm",
          "name": "Alarm",
          "inputs": [],
          "outputs": [
            "permit_ok",
            "alarm_latched",
            "supervisor_state"
          ],
          "variables": [],
          "code": "local field_bus = \"tripped\"\n",
          "hooks": {
            "onEnter": "setVal(\"permit_ok\", false)\nsetVal(\"alarm_latched\", true)\nsetVal(\"supervisor_state\", \"alarm\")\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 240
          }
        }
      },
      "transitions": {
        "inhibit_to_vote_pending": {
          "id": "inhibit_to_vote_pending",
          "name": "inhibit_to_vote_pending",
          "from": "Inhibit",
          "to": "VotePending",
          "type": "classic",
          "condition": "value(\"arm_request\") == true and value(\"route_state\") != \"fault_isolated\"",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "vote_to_permit": {
          "id": "vote_to_permit",
          "name": "vote_to_permit",
          "from": "VotePending",
          "to": "Permit",
          "type": "timed",
          "condition": "",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1,
          "timed": {
            "mode": "after",
            "delayMs": 250,
            "jitterMs": 0,
            "showCountdown": true
          }
        },
        "vote_to_alarm": {
          "id": "vote_to_alarm",
          "name": "vote_to_alarm",
          "from": "VotePending",
          "to": "Alarm",
          "type": "classic",
          "condition": "value(\"route_state\") == \"degraded_watch\" or value(\"route_state\") == \"fault_isolated\"",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "permit_to_interlock": {
          "id": "permit_to_interlock",
          "name": "permit_to_interlock",
          "from": "Permit",
          "to": "InterlockHold",
          "type": "classic",
          "condition": "value(\"arm_request\") == false or value(\"route_state\") == \"load_shedding\"",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "permit_to_alarm": {
