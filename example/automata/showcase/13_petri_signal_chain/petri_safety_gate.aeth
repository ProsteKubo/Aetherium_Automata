          "name": "permit_to_alarm",
          "from": "Permit",
          "to": "Alarm",
          "type": "classic",
          "condition": "value(\"route_state\") == \"fault_isolated\"",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "interlock_to_vote": {
          "id": "interlock_to_vote",
          "name": "interlock_to_vote",
          "from": "InterlockHold",
          "to": "VotePending",
          "type": "classic",
          "condition": "value(\"arm_request\") == true and value(\"route_state\") == \"backbone_sync\"",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "interlock_to_inhibit": {
          "id": "interlock_to_inhibit",
          "name": "interlock_to_inhibit",
          "from": "InterlockHold",
          "to": "Inhibit",
          "type": "classic",
          "condition": "value(\"arm_request\") == false",
          "body": "",
          "triggered": "",
          "priority": 1,
          "weight": 1
