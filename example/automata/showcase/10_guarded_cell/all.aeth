          "type": "bool",
          "direction": "output",
          "default": false
        },
        {
          "name": "permit_raw",
          "type": "bool",
          "direction": "output",
          "default": false
        },
        {
          "name": "leader_online",
          "type": "bool",
          "direction": "output",
          "default": false
        }
      ],
