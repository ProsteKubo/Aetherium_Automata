        },
        "monitoring_to_touch": {
          "id": "monitoring_to_touch",
          "name": "monitoring_to_touch",
          "from": "Monitoring",
          "to": "TouchActive",
          "type": "classic",
          "condition": "component(\"touch_pad\"):pressed()",
          "body": "",
