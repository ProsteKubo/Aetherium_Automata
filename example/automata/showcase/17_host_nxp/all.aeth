          "priority": 0,
          "weight": 1
        },
        "alerting_to_touch": {
          "id": "alerting_to_touch",
          "name": "alerting_to_touch",
          "from": "Alerting",
          "to": "TouchActive",
          "type": "classic",
          "condition": "component(\"touch_pad\"):pressed()",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "touch_to_dormant": {
          "id": "touch_to_dormant",
          "name": "touch_to_dormant",
          "from": "TouchActive",
          "to": "Dormant",
          "type": "classic",
          "condition": "not component(\"touch_pad\"):pressed() and (value(\"signal_level\") == \"idle\" or value(\"signal_level\") == \"cooldown\")",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "touch_to_monitoring": {
          "id": "touch_to_monitoring",
          "name": "touch_to_monitoring",
          "from": "TouchActive",
          "to": "Monitoring",
          "type": "classic",
          "condition": "not component(\"touch_pad\"):pressed() and (value(\"signal_level\") == \"low\" or value(\"signal_level\") == \"medium\")",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "touch_to_alerting": {
          "id": "touch_to_alerting",
          "name": "touch_to_alerting",
