        "dormant_to_touch": {
          "id": "dormant_to_touch",
          "name": "dormant_to_touch",
          "from": "Dormant",
          "to": "TouchActive",
          "type": "classic",
          "condition": "component(\"touch_pad\"):pressed()",
          "body": "",
