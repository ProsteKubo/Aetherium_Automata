    "network_showcase_17_host_nxp_01_nxp_signal_monitor": {
      "id": "network_showcase_17_host_nxp_01_nxp_signal_monitor",
      "version": "0.0.1",
      "config": {
        "name": "NXP Signal Monitor",
        "type": "inline",
        "language": "lua",
        "description": "FRDM-MCXN947 automata that monitors low, medium, and high signal levels from a host beacon, drives red/green LEDs accordingly, and locally overrides both LEDs while the onboard touch pad is pressed.",
        "tags": [
          "showcase",
          "mcxn947",
          "communication",
          "hardware-safe"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {
          "profile": "mcxn947_lua_v1"
        },
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Init",
      "states": {
        "Init": {
          "id": "Init",
          "name": "Init",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.mode(10, \"output\")\ngpio.mode(27, \"output\")\ngpio.write(10, false)\ngpio.write(27, false)\nsetOutput(\"red_led\", false)\nsetOutput(\"green_led\", false)\ncomponent(\"touch_pad\"):init()"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        },
        "Dormant": {
          "id": "Dormant",
          "name": "Dormant",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.write(10, false)\ngpio.write(27, false)\nsetOutput(\"red_led\", false)\nsetOutput(\"green_led\", false)\nsetOutput(\"nxp_touch_pressed\", false)"
          },
          "isComposite": false,
          "position": {
            "x": 400,
            "y": 80
          }
        },
        "Monitoring": {
          "id": "Monitoring",
          "name": "Monitoring",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.write(10, false)\ngpio.write(27, true)\nsetOutput(\"red_led\", false)\nsetOutput(\"green_led\", true)\nsetOutput(\"nxp_touch_pressed\", false)"
          },
          "isComposite": false,
          "position": {
            "x": 620,
            "y": 80
          }
        },
        "Alerting": {
          "id": "Alerting",
          "name": "Alerting",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.write(10, true)\ngpio.write(27, false)\nsetOutput(\"red_led\", true)\nsetOutput(\"green_led\", false)\nsetOutput(\"nxp_touch_pressed\", false)"
          },
          "isComposite": false,
          "position": {
            "x": 840,
            "y": 80
          }
        },
        "TouchActive": {
          "id": "TouchActive",
          "name": "TouchActive",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.write(10, true)\ngpio.write(27, true)\nsetOutput(\"red_led\", true)\nsetOutput(\"green_led\", true)\nsetOutput(\"nxp_touch_pressed\", true)"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 240
          }
        }
      },
