    "network_yaml_example_collection_01_blinking_led_test": {
      "id": "network_yaml_example_collection_01_blinking_led_test",
      "version": "0.0.1",
      "config": {
        "name": "Blinking LED Test",
        "type": "inline",
        "language": "lua",
        "description": "Simple 2-state automata for testing - blinks every 2 seconds",
        "tags": [
          "test",
          "simple",
          "timed"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {},
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "LED_OFF",
      "states": {
        "LED_OFF": {
          "id": "LED_OFF",
          "name": "LED_OFF",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "log(\"info\", \"💡 LED is now OFF - blink count: \" .. value(\"blink_count\"))\nsetVal(\"current_state_name\", \"off\")\n",
            "onTick": "-- Tick every 100ms while in this state\nlog(\"debug\", \"LED_OFF tick\")\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          },
          "description": "LED is off, waiting to turn on"
        },
        "LED_ON": {
          "id": "LED_ON",
          "name": "LED_ON",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "local count = value(\"blink_count\") + 1\nsetVal(\"blink_count\", count)\nsetVal(\"current_state_name\", \"on\")\nlog(\"info\", \"💡 LED is now ON - blink count: \" .. count)\n\n-- Simulated output\nif count % 5 == 0 then\n  log(\"warning\", \"🎉 Milestone! 5 blinks completed!\")\nend\n",
            "onTick": "log(\"debug\", \"LED_ON tick\")\n"
          },
          "isComposite": false,
          "position": {
            "x": 400,
            "y": 80
          },
          "description": "LED is on, waiting to turn off"
        }
      },
      "transitions": {
