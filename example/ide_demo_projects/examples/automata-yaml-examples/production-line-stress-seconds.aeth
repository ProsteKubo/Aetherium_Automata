        "Cooldown": {
          "id": "Cooldown",
          "name": "Cooldown",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "local cycles = value(\"cycle_count\")\nsetVal(\"cycle_count\", cycles + 1)\nif value(\"quality_score\") < value(\"target_quality\") then\n  setVal(\"alarm\", true)\nelse\n  setVal(\"alarm\", false)\nend\n"
          },
          "isComposite": false,
          "position": {
            "x": 400,
            "y": 240
          }
        },
        "Recovery": {
          "id": "Recovery",
          "name": "Recovery",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "local retries = value(\"retry_count\")\nsetVal(\"retry_count\", retries + 1)\nsetVal(\"alarm\", false)\nsetVal(\"selected_path\", \"recovery\")\n"
          },
          "isComposite": false,
          "position": {
