          "hooks": {
            "onEnter": "setVal(\"selected_path\", \"A\")\nlocal q = 40 + math.floor(rand() * 60)\nsetVal(\"quality_score\", q)\nlog(\"debug\", \"process A quality=\" .. q)\n"
          },
