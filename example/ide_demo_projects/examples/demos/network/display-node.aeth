          "from": "ShowingNormal",
          "to": "ShowingNormal",
          "type": "timed",
          "condition": "value(\"refresh_count\") < 3",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1,
          "timed": {
            "mode": "after",
            "delayMs": 3000,
            "jitterMs": 0,
            "showCountdown": true
          }
        },
        "to_warning": {
          "id": "to_warning",
          "name": "to_warning",
          "from": "ShowingNormal",
          "to": "ShowingWarning",
          "type": "timed",
          "condition": "value(\"refresh_count\") >= 3 and value(\"refresh_count\") < 5",
