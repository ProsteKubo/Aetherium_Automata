          "from": "ShowingNormal",
          "to": "ShowingCritical",
          "type": "timed",
          "condition": "value(\"refresh_count\") >= 5 and value(\"refresh_count\") < 7",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1,
          "timed": {
            "mode": "after",
            "delayMs": 3000,
            "jitterMs": 0,
