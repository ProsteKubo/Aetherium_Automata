        "type": "inline",
        "language": "lua",
        "description": "Turns arm requests into permits while sharing the same field bus as downstream nodes.",
        "tags": [
          "showcase",
          "petri",
          "signal-chain",
          "safety"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
