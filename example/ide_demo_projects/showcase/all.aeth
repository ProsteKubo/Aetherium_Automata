            "onEnter": "setVal(\"pump_enabled\", false)\nsetVal(\"drain_enabled\", false)\nsetVal(\"alarm\", false)\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        },
        "Fill": {
          "id": "Fill",
          "name": "Fill",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
