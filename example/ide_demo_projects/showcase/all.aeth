      "id": "network_showcase_collection_01_blink_with_manual_override",
      "version": "0.0.1",
      "config": {
        "name": "Blink With Manual Override",
        "type": "inline",
        "language": "lua",
        "description": "Small deterministic automata with timed transitions and manual override input.",
        "tags": [
          "showcase",
          "basics",
          "timed",
          "control"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {},
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Off",
      "states": {
        "Off": {
          "id": "Off",
          "name": "Off",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "setVal(\"led_on\", false)\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        },
        "On": {
          "id": "On",
          "name": "On",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "setVal(\"led_on\", true)\nsetVal(\"blink_count\", value(\"blink_count\") + 1)\n"
          },
          "isComposite": false,
          "position": {
            "x": 400,
            "y": 80
          }
        },
        "ForcedOn": {
          "id": "ForcedOn",
          "name": "ForcedOn",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "setVal(\"led_on\", true)\n"
          },
          "isComposite": false,
          "position": {
            "x": 620,
            "y": 80
          }
        }
      },
      "transitions": {
        "off_force": {
          "id": "off_force",
          "name": "off_force",
          "from": "Off",
          "to": "ForcedOn",
          "type": "classic",
          "condition": "value(\"force_on\") == true",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "on_force": {
          "id": "on_force",
          "name": "on_force",
          "from": "On",
          "to": "ForcedOn",
          "type": "classic",
          "condition": "value(\"force_on\") == true",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "release_force": {
          "id": "release_force",
          "name": "release_force",
          "from": "ForcedOn",
          "to": "Off",
          "type": "classic",
          "condition": "value(\"force_on\") == false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "off_to_on": {
          "id": "off_to_on",
          "name": "off_to_on",
          "from": "Off",
          "to": "On",
          "type": "timed",
          "condition": "",
          "body": "",
          "triggered": "",
          "priority": 1,
          "weight": 1,
          "timed": {
            "mode": "after",
            "delayMs": 700,
            "jitterMs": 0,
            "showCountdown": true
          }
        },
        "on_to_off": {
          "id": "on_to_off",
          "name": "on_to_off",
          "from": "On",
          "to": "Off",
          "type": "timed",
          "condition": "",
          "body": "",
          "triggered": "",
          "priority": 1,
          "weight": 1,
          "timed": {
            "mode": "after",
