          "position": {
            "x": 620,
            "y": 80
          }
        },
        "Alarm": {
          "id": "Alarm",
          "name": "Alarm",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "setVal(\"pump_enabled\", false)\nsetVal(\"drain_enabled\", true)\nsetVal(\"alarm\", true)\n"
