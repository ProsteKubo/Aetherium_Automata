          "isComposite": false,
          "position": {
            "x": 840,
            "y": 80
          }
        }
      },
      "transitions": {
        "idle_to_fill": {
          "id": "idle_to_fill",
          "name": "idle_to_fill",
          "from": "Idle",
          "to": "Fill",
          "type": "classic",
          "condition": "value(\"level\") <= 25",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "fill_to_drain": {
          "id": "fill_to_drain",
          "name": "fill_to_drain",
          "from": "Fill",
          "to": "Drain",
          "type": "classic",
          "condition": "value(\"level\") >= 85",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "drain_to_fill": {
          "id": "drain_to_fill",
          "name": "drain_to_fill",
          "from": "Drain",
          "to": "Fill",
          "type": "classic",
          "condition": "value(\"level\") <= 30",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "fill_overflow_alarm": {
          "id": "fill_overflow_alarm",
          "name": "fill_overflow_alarm",
          "from": "Fill",
          "to": "Alarm",
          "type": "event",
