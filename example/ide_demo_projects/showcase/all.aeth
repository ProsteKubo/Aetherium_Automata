          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "setVal(\"pump_enabled\", false)\nsetVal(\"drain_enabled\", true)\nsetVal(\"cycle_count\", value(\"cycle_count\") + 1)\n"
