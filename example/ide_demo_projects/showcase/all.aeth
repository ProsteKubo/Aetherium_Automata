          "id": "Sense",
          "name": "Sense",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "local temp_mc = component(\"board_temp\"):read_milli_c()\nlocal temp_ok = temp_mc >= 10000 and temp_mc <= 45000\nlocal temp_warm = temp_mc >= 27000\n\ngpio.write(27, temp_ok)\ngpio.write(10, temp_warm)\n\nsetOutput(\"temp_mc\", temp_mc)\nsetOutput(\"temp_ok\", temp_ok)\nsetOutput(\"temp_warm\", temp_warm)\nsetOutput(\"temp_delta_mc\", 0)",
          "hooks": {
            "onEnter": "gpio.mode(10, \"output\")\ngpio.mode(27, \"output\")\ncomponent(\"board_temp\"):init()"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        }
      },
      "transitions": {
        "stay_active": {
          "id": "stay_active",
          "name": "stay_active",
