    "network_showcase_collection_29_esp32_bidirectional_loop_node": {
      "id": "network_showcase_collection_29_esp32_bidirectional_loop_node",
      "version": "0.0.1",
      "config": {
        "name": "ESP32 Bidirectional Loop Node",
        "type": "inline",
        "language": "lua",
        "description": "ESP32 node for the bidirectional loop demo. Samples a potentiometer and drives a local LED from the host command path.",
        "tags": [
          "showcase",
          "esp32",
          "ide",
          "adc",
          "pwm",
          "bidirectional",
          "hardware-safe"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {
          "profile": "esp32_lua_v1"
        },
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Loop",
      "states": {
        "Loop": {
          "id": "Loop",
          "name": "Loop",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "if next_sample_at ~= nil and now() < next_sample_at then\n  return\nend\n\nnext_sample_at = now() + 80\n\nlocal pot = adc.read(34)\nlocal mv = adc.read_mv(34)\nlocal duty = remote_duty or 0\n\nif duty < 0 then\n  duty = 0\nelseif duty > 255 then\n  duty = 255\nend\n\npwm.write(0, duty)\nsetOutput(\"pot_raw\", pot)\nsetOutput(\"pot_mv\", mv)\nsetOutput(\"esp_online\", true)",
          "hooks": {
            "onEnter": "pwm.attach(0, 18, 5000, 8)\nnext_sample_at = 0"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        }
      },
      "transitions": {
        "stay_active": {
          "id": "stay_active",
          "name": "stay_active",
          "from": "Loop",
          "to": "Loop",
          "type": "classic",
          "condition": "false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        }
      },
      "variables": [
        {
          "name": "remote_duty",
          "type": "int",
          "direction": "input",
          "default": 0
        },
        {
          "name": "pot_raw",
          "type": "int",
          "direction": "output",
          "default": 0
        },
        {
          "name": "pot_mv",
          "type": "int",
          "direction": "output",
          "default": 0
        },
        {
          "name": "esp_online",
          "type": "bool",
          "direction": "output",
          "default": false
        }
      ],
      "inputs": [
        "remote_duty"
      ],
      "outputs": [
        "pot_raw",
        "pot_mv",
        "esp_online"
      ],
      "nestedAutomataIds": [],
      "filePath": "example/automata/showcase/11_bidirectional_loop/esp32_bidirectional_loop_node.yaml",
      "isDirty": false
    },
    "network_showcase_collection_30_mcxn947_bidirectional_loop_node": {
      "id": "network_showcase_collection_30_mcxn947_bidirectional_loop_node",
      "version": "0.0.1",
      "config": {
        "name": "MCXN947 Bidirectional Loop Node",
        "type": "inline",
        "language": "lua",
        "description": "FRDM-MCXN947 peer node for the bidirectional loop demo. Exports button and touch input while mirroring host-driven LED commands locally.",
        "tags": [
          "showcase",
          "mcxn947",
          "ide",
          "touch",
          "gpio",
          "bidirectional",
          "hardware-safe"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {
          "profile": "mcxn947_lua_v1"
        },
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Loop",
      "states": {
        "Loop": {
          "id": "Loop",
          "name": "Loop",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "local sw2 = gpio.read(23) == 0\nlocal touch = component(\"touch_pad\"):pressed()\n\ngpio.write(10, remote_red == true)\ngpio.write(27, remote_green == true)\n\nsetOutput(\"sw2_pressed\", sw2)\nsetOutput(\"touch_pressed\", touch)\nsetOutput(\"nxp_online\", true)",
          "hooks": {
            "onEnter": "gpio.mode(10, \"output\")\ngpio.mode(27, \"output\")\ngpio.mode(23, \"input_pullup\")\ncomponent(\"touch_pad\"):init()"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        }
      },
      "transitions": {
        "stay_active": {
          "id": "stay_active",
          "name": "stay_active",
          "from": "Loop",
          "to": "Loop",
          "type": "classic",
          "condition": "false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        }
      },
      "variables": [
        {
          "name": "remote_red",
          "type": "bool",
          "direction": "input",
          "default": false
        },
        {
          "name": "remote_green",
          "type": "bool",
          "direction": "input",
          "default": false
        },
        {
          "name": "sw2_pressed",
          "type": "bool",
          "direction": "output",
          "default": false
        },
        {
          "name": "touch_pressed",
          "type": "bool",
          "direction": "output",
          "default": false
        },
        {
          "name": "nxp_online",
          "type": "bool",
          "direction": "output",
          "default": false
        }
      ],
      "inputs": [
        "remote_red",
        "remote_green"
      ],
      "outputs": [
        "sw2_pressed",
        "touch_pressed",
        "nxp_online"
      ],
      "nestedAutomataIds": [],
      "filePath": "example/automata/showcase/11_bidirectional_loop/mcxn947_bidirectional_loop_node.yaml",
      "isDirty": false
    },
