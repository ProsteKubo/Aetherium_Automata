    "network_showcase_19_esp_nxp_01_01_gpio_write_esp32": {
      "id": "network_showcase_19_esp_nxp_01_01_gpio_write_esp32",
      "version": "0.0.1",
      "config": {
        "name": "ESP-NXP 01 - ESP32 GPIO Write",
        "type": "inline",
        "language": "lua",
        "description": "Step 1: Blinks LED on IO23 every 1s. Verifies GPIO output on ESP32. Wire: LED+ to IO23, LED- through 330Ω to GND.",
        "tags": [
          "showcase",
          "esp32",
          "gpio",
          "output",
          "led"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {
          "profile": "esp32_lua_v1"
        },
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Off",
      "states": {
        "Off": {
          "id": "Off",
          "name": "Off",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.mode(23, \"output\")\ngpio.write(23, 0)\nsetOutput(\"led_on\", false)\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        },
        "On": {
          "id": "On",
          "name": "On",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.write(23, 1)\nsetOutput(\"led_on\", true)\n"
          },
          "isComposite": false,
          "position": {
            "x": 400,
            "y": 80
          }
        }
      },
      "transitions": {
        "turn_on": {
          "id": "turn_on",
          "name": "turn_on",
          "from": "Off",
          "to": "On",
          "type": "timed",
          "condition": "",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1,
          "timed": {
            "mode": "after",
            "delayMs": 1000,
            "jitterMs": 0,
            "showCountdown": true
          }
        },
        "turn_off": {
          "id": "turn_off",
          "name": "turn_off",
          "from": "On",
