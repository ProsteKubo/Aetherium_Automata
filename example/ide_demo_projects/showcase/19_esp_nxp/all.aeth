    "network_showcase_19_esp_nxp_03_02_gpio_read_esp32": {
      "id": "network_showcase_19_esp_nxp_03_02_gpio_read_esp32",
      "version": "0.0.1",
      "config": {
        "name": "ESP-NXP 02 - ESP32 GPIO Read (ADC IO34)",
        "type": "inline",
        "language": "lua",
        "description": "Step 2: Reads analog sensor on IO34 via ADC. Above 1650mV (half of 3.3V) sets sensor_high=true and lights LED on IO23. Wire sensor signal to IO34, VCC to 3.3V, GND to GND.",
        "tags": [
          "showcase",
          "esp32",
          "gpio",
          "input",
          "adc",
          "sensor",
          "led"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {
          "profile": "esp32_lua_v1"
        },
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Sense",
      "states": {
        "Sense": {
          "id": "Sense",
          "name": "Sense",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "local mv = adc.read_mv(34)\nlocal high = mv > 1650\ngpio.write(23, high and 1 or 0)\nsetOutput(\"sensor_mv\", mv)\nsetOutput(\"sensor_high\", high)\n",
          "hooks": {
            "onEnter": "gpio.mode(23, \"output\")\ngpio.write(23, 0)\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        }
      },
      "transitions": {
        "stay": {
          "id": "stay",
          "name": "stay",
          "from": "Sense",
          "to": "Sense",
          "type": "classic",
          "condition": "false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        }
      },
      "variables": [
        {
          "name": "sensor_mv",
          "type": "int",
          "direction": "output",
          "default": 0
        },
        {
          "name": "sensor_high",
          "type": "bool",
          "direction": "output",
          "default": false
        }
      ],
      "inputs": [],
      "outputs": [
        "sensor_mv",
        "sensor_high"
      ],
      "nestedAutomataIds": [],
      "filePath": "example/automata/showcase/19_esp_nxp/02_gpio_read_esp32.yaml",
      "isDirty": false
    },
    "network_showcase_19_esp_nxp_04_02_gpio_read_nxp": {
      "id": "network_showcase_19_esp_nxp_04_02_gpio_read_nxp",
      "version": "0.0.1",
      "config": {
        "name": "ESP-NXP 02 - NXP GPIO Read (Buttons)",
        "type": "inline",
        "language": "lua",
        "description": "Step 2 (NXP): Reads SW2 (pin 23) and SW3 (pin 6) onboard buttons. SW2 pressed = red LED (pin 10), SW3 pressed = green LED (pin 27), neither = both off. Buttons are active-low with internal pullup.",
        "tags": [
          "showcase",
          "mcxn947",
          "gpio",
          "input",
          "button",
          "led"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {
          "profile": "mcxn947_lua_v1"
        },
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Monitor",
      "states": {
        "Monitor": {
          "id": "Monitor",
          "name": "Monitor",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "local sw2 = gpio.read(23) == 0\nlocal sw3 = gpio.read(6) == 0\ngpio.write(10, sw2 and 1 or 0)\ngpio.write(27, sw3 and 1 or 0)\nsetOutput(\"sw2_pressed\", sw2)\nsetOutput(\"sw3_pressed\", sw3)\n",
          "hooks": {
            "onEnter": "gpio.mode(10, \"output\")\ngpio.mode(27, \"output\")\ngpio.mode(23, \"input_pullup\")\ngpio.mode(6, \"input_pullup\")\ngpio.write(10, 0)\ngpio.write(27, 0)\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        }
      },
      "transitions": {
        "stay": {
          "id": "stay",
          "name": "stay",
          "from": "Monitor",
          "to": "Monitor",
          "type": "classic",
          "condition": "false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        }
      },
      "variables": [
        {
          "name": "sw2_pressed",
          "type": "bool",
          "direction": "output",
          "default": false
        },
        {
          "name": "sw3_pressed",
          "type": "bool",
          "direction": "output",
          "default": false
        }
      ],
      "inputs": [],
      "outputs": [
        "sw2_pressed",
        "sw3_pressed"
      ],
      "nestedAutomataIds": [],
      "filePath": "example/automata/showcase/19_esp_nxp/02_gpio_read_nxp.yaml",
      "isDirty": false
    },
