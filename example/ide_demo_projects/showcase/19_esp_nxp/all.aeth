    "network_showcase_19_esp_nxp_07_04_trio_esp32": {
      "id": "network_showcase_19_esp_nxp_07_04_trio_esp32",
      "version": "0.0.1",
      "config": {
        "name": "ESP-NXP 04 - Trio ESP32 Side",
        "type": "inline",
        "language": "lua",
        "description": "Step 4 (ESP side): Receives mode from the stochastic host via gateway. LED on IO23: off=idle, slow 1s blink=active, fast 250ms blink=alert.",
        "tags": [
          "showcase",
          "esp32",
          "gpio",
          "led",
          "comms",
          "stochastic"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {
          "profile": "esp32_lua_v1"
        },
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Running",
      "states": {
        "Running": {
          "id": "Running",
          "name": "Running",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "local m = value(\"mode\")\nlocal t = now()\n\nif m == \"idle\" then\n  gpio.write(23, 0)\n  led_state = 0\n  last_toggle = t\nelseif m == \"active\" then\n  if t - last_toggle >= 1000 then\n    led_state = 1 - led_state\n    gpio.write(23, led_state)\n    last_toggle = t\n  end\nelseif m == \"alert\" then\n  if t - last_toggle >= 250 then\n    led_state = 1 - led_state\n    gpio.write(23, led_state)\n    last_toggle = t\n  end\nend\n",
          "hooks": {
            "onEnter": "gpio.mode(23, \"output\")\ngpio.write(23, 0)\nlast_toggle = 0\nled_state = 0\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        }
      },
      "transitions": {
        "stay": {
          "id": "stay",
          "name": "stay",
          "from": "Running",
          "to": "Running",
          "type": "classic",
          "condition": "false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        }
      },
      "variables": [
        {
          "name": "mode",
          "type": "string",
          "direction": "input",
          "default": "idle"
        }
      ],
      "inputs": [
        "mode"
      ],
      "outputs": [],
      "nestedAutomataIds": [],
      "filePath": "example/automata/showcase/19_esp_nxp/04_trio_esp32.yaml",
      "isDirty": false
    },
