    "network_showcase_19_esp_nxp_02_01_gpio_write_nxp": {
      "id": "network_showcase_19_esp_nxp_02_01_gpio_write_nxp",
      "version": "0.0.1",
      "config": {
        "name": "ESP-NXP 01 - NXP GPIO Write",
        "type": "inline",
        "language": "lua",
        "description": "Step 1 (NXP): Alternates red (pin 10) and green (pin 27) LEDs on FRDM-MCXN947 every 1s. Verifies GPIO output. Pins are active-low on the board.",
        "tags": [
          "showcase",
          "mcxn947",
          "gpio",
          "output",
          "led"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {
          "profile": "mcxn947_lua_v1"
        },
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Red",
      "states": {
        "Red": {
          "id": "Red",
          "name": "Red",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.mode(10, \"output\")\ngpio.mode(27, \"output\")\ngpio.write(10, 1)\ngpio.write(27, 0)\nsetOutput(\"led_state\", \"red\")\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        },
        "Green": {
          "id": "Green",
          "name": "Green",
          "inputs": [],
          "outputs": [],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "gpio.write(10, 0)\ngpio.write(27, 1)\nsetOutput(\"led_state\", \"green\")\n"
          },
          "isComposite": false,
          "position": {
            "x": 400,
            "y": 80
          }
        }
      },
      "transitions": {
        "red_to_green": {
          "id": "red_to_green",
          "name": "red_to_green",
          "from": "Red",
          "to": "Green",
          "type": "timed",
          "condition": "",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1,
          "timed": {
            "mode": "after",
            "delayMs": 1000,
            "jitterMs": 0,
            "showCountdown": true
          }
        },
        "green_to_red": {
          "id": "green_to_red",
          "name": "green_to_red",
          "from": "Green",
          "to": "Red",
          "type": "timed",
          "condition": "",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1,
          "timed": {
            "mode": "after",
            "delayMs": 1000,
            "jitterMs": 0,
            "showCountdown": true
          }
        }
      },
      "variables": [
        {
          "name": "led_state",
          "type": "string",
