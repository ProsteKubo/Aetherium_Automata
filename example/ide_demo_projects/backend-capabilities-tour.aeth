    "modified": 1775044800000
  },
  "networks": [
    {
      "id": "network_tour_signal_chain",
      "name": "Petri Signal Chain",
      "description": "Operator-to-drive signal chain with derived bindings and one sealed drive automaton.",
      "rootAutomataIds": [
        "network_tour_signal_chain_01_petri_command_router",
        "network_tour_signal_chain_02_petri_safety_gate",
        "network_tour_signal_chain_03_petri_drive_unit_black_box",
