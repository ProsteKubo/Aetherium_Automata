    "network_signal_chain_02_petri_safety_gate": {
      "id": "network_signal_chain_02_petri_safety_gate",
      "version": "0.0.1",
      "config": {
        "name": "Petri Safety Gate",
        "type": "inline",
        "language": "lua",
        "description": "Flagship signal-chain safety gate that reviews route phases before granting permit to the downstream drive unit.",
