{
  "schemaVersion": "1.0.0",
  "metadata": {
    "name": "Backend Capabilities Tour",
    "version": "0.1.0",
    "description": "All-in-one presentation project with one network each for Petri conversion, analyzer contention, and black-box contract inspection.",
    "author": "Aetherium Team",
    "tags": [
      "demo",
      "petri",
      "analyzer",
      "black-box",
      "presentation"
    ],
