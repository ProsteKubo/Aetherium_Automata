        },
        {
          "name": "alarm_latched",
          "type": "bool",
          "direction": "input",
          "default": false
        },
        {
          "name": "dashboard_ready",
          "type": "bool",
          "direction": "output",
          "default": false
        },
        {
          "name": "telemetry_state",
          "type": "string",
