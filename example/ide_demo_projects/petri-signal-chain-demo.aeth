    {
      "id": "network_signal_chain",
      "name": "Signal Chain",
      "description": "Four automata laid out to highlight Petri grouping, shared field-bus resources, and a sealed drive node.",
      "rootAutomataIds": [
        "network_signal_chain_01_petri_command_router",
        "network_signal_chain_02_petri_safety_gate",
