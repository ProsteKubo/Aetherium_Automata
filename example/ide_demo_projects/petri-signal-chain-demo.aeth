    "network_signal_chain_04_petri_telemetry_observer": {
      "id": "network_signal_chain_04_petri_telemetry_observer",
      "version": "0.0.1",
      "config": {
        "name": "Petri Telemetry Observer",
        "type": "inline",
        "language": "lua",
        "description": "Observes heartbeat, drive status, and alarm flow for the Petri signal-chain demo.",
        "tags": [
          "showcase",
          "petri",
          "signal-chain",
          "telemetry"
        ],
        "author": "Aetherium Team",
        "version": "1.0.0",
        "target": {},
        "created": 1775044800000,
        "modified": 1775044800000
      },
      "initialState": "Quiet",
      "states": {
        "Quiet": {
          "id": "Quiet",
          "name": "Quiet",
          "inputs": [
            "heartbeat",
            "module_status",
            "alarm_latched"
          ],
          "outputs": [
            "dashboard_ready",
            "telemetry_state"
          ],
          "variables": [],
          "code": "local field_bus = \"listening\"\n",
          "hooks": {
            "onEnter": "setVal(\"dashboard_ready\", false)\nsetVal(\"telemetry_state\", \"quiet\")\n"
          },
          "isComposite": false,
          "position": {
            "x": 180,
            "y": 80
          }
        },
        "Streaming": {
          "id": "Streaming",
          "name": "Streaming",
          "inputs": [
            "heartbeat",
            "module_status"
          ],
          "outputs": [
            "dashboard_ready",
            "telemetry_state"
          ],
          "variables": [],
          "code": "local field_bus = \"streaming\"\n",
          "hooks": {
            "onEnter": "setVal(\"dashboard_ready\", true)\nsetVal(\"telemetry_state\", value(\"module_status\"))\n"
          },
          "isComposite": false,
          "position": {
            "x": 400,
            "y": 80
          }
        },
        "Alarmed": {
          "id": "Alarmed",
          "name": "Alarmed",
          "inputs": [
            "alarm_latched"
          ],
          "outputs": [
            "dashboard_ready",
            "telemetry_state"
          ],
          "variables": [],
          "code": "",
          "hooks": {
            "onEnter": "setVal(\"dashboard_ready\", true)\nsetVal(\"telemetry_state\", \"alarm\")\n"
          },
          "isComposite": false,
          "position": {
            "x": 620,
            "y": 80
          }
        }
      },
      "transitions": {
        "quiet_to_streaming": {
          "id": "quiet_to_streaming",
          "name": "quiet_to_streaming",
          "from": "Quiet",
          "to": "Streaming",
          "type": "classic",
          "condition": "value(\"heartbeat\") == true and value(\"alarm_latched\") == false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "streaming_to_quiet": {
          "id": "streaming_to_quiet",
          "name": "streaming_to_quiet",
          "from": "Streaming",
          "to": "Quiet",
          "type": "classic",
          "condition": "value(\"heartbeat\") == false and value(\"alarm_latched\") == false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "any_to_alarmed": {
          "id": "any_to_alarmed",
          "name": "any_to_alarmed",
          "from": "Streaming",
          "to": "Alarmed",
          "type": "classic",
          "condition": "value(\"alarm_latched\") == true",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        },
        "alarmed_to_quiet": {
          "id": "alarmed_to_quiet",
          "name": "alarmed_to_quiet",
          "from": "Alarmed",
          "to": "Quiet",
          "type": "classic",
          "condition": "value(\"alarm_latched\") == false and value(\"heartbeat\") == false",
          "body": "",
          "triggered": "",
          "priority": 0,
          "weight": 1
        }
      },
      "variables": [
