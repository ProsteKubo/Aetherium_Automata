FROM docker.io/elixir:1.19-alpine

# Runtime deps for dev reload + native deps (e.g. circuits_uart NIF build).
RUN apk add --no-cache inotify-tools build-base linux-headers

WORKDIR /app

RUN mix local.hex --force && mix local.rebar --force

COPY mix.exs mix.lock ./
COPY config config/

RUN mix deps.get

COPY . .

RUN mix compile

EXPOSE 4000

CMD ["mix", "run", "--no-halt"]
